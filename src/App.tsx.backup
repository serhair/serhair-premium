            <div>
              <span style={{ fontFamily: "var(--font-display)", fontSize: "2.5rem", color: primaryGold, display: "block" }}>{counts.greft.toLocaleString()}+</span>
              <span style={{ fontFamily: "var(--font-body)", fontSize: "0.75rem", fontWeight: 500, letterSpacing: "0.12em", color: textMedium, textTransform: "uppercase" }}>Ekilmiş Greft</span>
