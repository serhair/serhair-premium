              onMouseLeave={(e) => { e.currentTarget.style.opacity = "0.6"; e.currentTarget.style.borderColor = textDark; }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={textDark} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </a>
            <a href="https://youtube.com/@serhair" target="_blank" rel="noopener noreferrer" style={{ width: 36, height: 36, borderRadius: "50%", border: `1px solid ${textDark}`, display: "flex", alignItems: "center", justifyContent: "center", cursor: "pointer", transition: "all 0.3s ease", textDecoration: "none", opacity: 0.6 }}
              onMouseEnter={(e) => { e.currentTarget.style.opacity = "1"; e.currentTarget.style.borderColor = primaryGold; }}
              onMouseLeave={(e) => { e.currentTarget.style.opacity = "0.6"; e.currentTarget.style.borderColor = textDark; }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={textDark} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.46z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
            </a>
            <a href="https://tiktok.com/@serhair1" target="_blank" rel="noopener noreferrer" style={{ width: 36, height: 36, borderRadius: "50%", border: `1px solid ${textDark}`, display: "flex", alignItems: "center", justifyContent: "center", cursor: "pointer", transition: "all 0.3s ease", textDecoration: "none", opacity: 0.6 }}
              onMouseEnter={(e) => { e.currentTarget.style.opacity = "1"; e.currentTarget.style.borderColor = primaryGold; }}
              onMouseLeave={(e) => { e.currentTarget.style.opacity = "0.6"; e.currentTarget.style.borderColor = textDark; }}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={textDark} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
          </div>
        </div>
        {/* Google Maps */}
        <div style={{ marginTop: 32, border: `1px solid ${borderLight}`, overflow: "hidden" }}>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3061.5!2d32.85!3d39.93!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMznCsDU1JzYwLjQiTiAzMsKwNTEnMDAuMCJF!5e0!3m2!1str!2str!4v1"
            width="100%"
            height="280"
            style={{ border: 0, filter: "grayscale(20%) contrast(1.1)" }}
            allowFullScreen
            loading="lazy"
            referrerPolicy="no-referrer-when-downgrade"
            title="SerHair Center Konum"
          />
        </div>
        <div style={{ background: charcoal, padding: 48 }}>
          {status === "success" ? (
            <div style={{ textAlign: "center", padding: "40px 0" }}>
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke={primaryGold} strokeWidth="2"/><path d="M16 24l6 6 10-10" stroke={primaryGold} strokeWidth="2"/></svg>
              <p style={{ fontFamily: "var(--font-display)", fontSize: "1.5rem", color: bgWhite, marginTop: 20 }}>Teşekkürler!</p>
              <p style={{ fontFamily: "var(--font-body)", fontSize: "1rem", color: textLight, marginTop: 8 }}>Mesajınız serhair1@gmail.com adresine iletildi. En kısa sürede size dönüş yapacağız.</p>
            </div>
          ) : status === "error" ? (
            <div style={{ textAlign: "center", padding: "40px 0" }}>
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#c44" strokeWidth="2"/><path d="M16 16l16 16M32 16l-16 16" stroke="#c44" strokeWidth="2"/></svg>
              <p style={{ fontFamily: "var(--font-display)", fontSize: "1.5rem", color: bgWhite, marginTop: 20 }}>Hata Oluştu</p>
              <p style={{ fontFamily: "var(--font-body)", fontSize: "1rem", color: textLight, marginTop: 8 }}>Lütfen tekrar deneyin veya telefon ile ulaşın.</p>
              <button onClick={() => setStatus("idle")} style={{ marginTop: 20, fontFamily: "var(--font-body)", fontSize: "0.875rem", fontWeight: 500, letterSpacing: "0.1em", textTransform: "uppercase", color: textDark, background: bgWhite, border: "none", padding: "12px 24px", cursor: "pointer" }}>TEKRAR DENE</button>
            </div>
          ) : (
            <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: 20 }}>
              <input
                type="text"
                name="name"
                placeholder="Ad Soyad"
                required
                value={formData.name}
                onChange={(e) => setFormData({ ...formData, name: e.target.value })}
                style={{ background: "transparent", border: "none", borderBottom: "1px solid rgba(255,251,240,0.3)", padding: "12px 0", color: bgWhite, fontFamily: "var(--font-body)", fontSize: "1rem", outline: "none", transition: "border-color 0.3s" }}
                onFocus={(e) => { e.currentTarget.style.borderBottomColor = bgWhite; }}
                onBlur={(e) => { e.currentTarget.style.borderBottomColor = "rgba(255,251,240,0.3)"; }}
              />
              <input
                type="tel"
                name="phone"
                placeholder="Telefon"
                required
                value={formData.phone}
                onChange={(e) => setFormData({ ...formData, phone: e.target.value })}
                style={{ background: "transparent", border: "none", borderBottom: "1px solid rgba(255,251,240,0.3)", padding: "12px 0", color: bgWhite, fontFamily: "var(--font-body)", fontSize: "1rem", outline: "none", transition: "border-color 0.3s" }}
                onFocus={(e) => { e.currentTarget.style.borderBottomColor = bgWhite; }}
                onBlur={(e) => { e.currentTarget.style.borderBottomColor = "rgba(255,251,240,0.3)"; }}
              />
              <input
                type="email"
                name="email"
                placeholder="E-posta"
                required
                value={formData.email}
                onChange={(e) => setFormData({ ...formData, email: e.target.value })}
                style={{ background: "transparent", border: "none", borderBottom: "1px solid rgba(255,251,240,0.3)", padding: "12px 0", color: bgWhite, fontFamily: "var(--font-body)", fontSize: "1rem", outline: "none", transition: "border-color 0.3s" }}
                onFocus={(e) => { e.currentTarget.style.borderBottomColor = bgWhite; }}
                onBlur={(e) => { e.currentTarget.style.borderBottomColor = "rgba(255,251,240,0.3)"; }}
              />
              <textarea
                name="message"
                placeholder="Mesajınız"
                rows={3}
                required
                value={formData.message}
                onChange={(e) => setFormData({ ...formData, message: e.target.value })}
                style={{ background: "transparent", border: "none", borderBottom: "1px solid rgba(255,251,240,0.3)", padding: "12px 0", color: bgWhite, fontFamily: "var(--font-body)", fontSize: "1rem", outline: "none", resize: "none", transition: "border-color 0.3s" }}
                onFocus={(e) => { e.currentTarget.style.borderBottomColor = bgWhite; }}
                onBlur={(e) => { e.currentTarget.style.borderBottomColor = "rgba(255,251,240,0.3)"; }}
              />
              <button
                type="submit"
                disabled={status === "sending"}
                style={{
                  fontFamily: "var(--font-body)", fontSize: "0.875rem", fontWeight: 500, letterSpacing: "0.1em", textTransform: "uppercase",
                  color: textDark, background: status === "sending" ? offWhite : bgWhite, border: "none", padding: "16px", cursor: status === "sending" ? "wait" : "pointer", transition: "background 0.3s ease", marginTop: 12, opacity: status === "sending" ? 0.7 : 1,
                }}
                onMouseEnter={(e) => { if (status !== "sending") e.currentTarget.style.background = offWhite; }}
                onMouseLeave={(e) => { if (status !== "sending") e.currentTarget.style.background = bgWhite; }}
              >
                {status === "sending" ? "GÖNDERİLİYOR..." : "GÖNDER"}
              </button>
            </form>
          )}
        </div>
      </div>
    </section>
  );
};

