          onMouseEnter={() => setIsPaused(true)}
          onMouseLeave={() => setIsPaused(false)}
        >
          {testimonials.map((t, i) => (
            <div
              key={i}
              style={{
                background: cream,
                padding: 40,
                display: i === activeIndex ? "block" : "none",
                animation: i === activeIndex ? "fadeIn 0.5s ease" : "none",
              }}
            >
              <span style={{ fontFamily: "var(--font-display)", fontSize: "4rem", color: primaryGold, opacity: 0.2, lineHeight: 1, display: "block", marginBottom: 16 }}>"</span>
              <p style={{ fontFamily: "var(--font-body)", fontSize: "1.125rem", color: textDark, lineHeight: 1.8, fontStyle: "italic", marginBottom: 32 }}>
                {t.quote}
