  const testimonials = [
    { quote: "SerHair'deki deneyimim harikaydı. 8 ay sonra doğal ve gururla tarayabileceğim saçlara kavuştum.", name: "Ahmet Y.", op: "DHI Saç Ekimi", img: "/assets/img-testimonial-1.jpg" },
    { quote: "Profesyonel ekip, modern klinik ve muhteşem sonuç. Kendimi 10 yaş genç hissediyorum. Kesinlikle tavsiye ederim!", name: "Mehmet K.", op: "FUE Saç Ekimi", img: "/assets/img-testimonial-2.jpg" },
    { quote: "Sakal ekimi için araştırma yaparken SerHair'i buldum. Sonuçtan çok memnunum, doğal ve dolgun bir sakalım oldu.", name: "Burak C.", op: "Sakal Ekimi", img: "/assets/img-testimonial-3.jpg" },
  ];

  const [activeIndex, setActiveIndex] = useState(0);
  const [isPaused, setIsPaused] = useState(false);

  useEffect(() => {
    if (isPaused) return;
    const interval = setInterval(() => {
      setActiveIndex((prev) => (prev + 1) % testimonials.length);
    }, 5000);
    return () => clearInterval(interval);
  }, [isPaused, testimonials.length]);

  return (
    <section style={{ background: offWhite, padding: "120px 24px" }}>
      <div style={{ maxWidth: 1280, margin: "0 auto" }}>
        <SectionHeader label="YORUMLAR" title="Mutlu Hastalarımızın Deneyimleri" />
