import { useEffect, useRef, useState, useCallback } from "react";
import gsap from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import SplitType from "split-type";
import HairGrowthScene from "./components/HairGrowthScene";

gsap.registerPlugin(ScrollTrigger);

const primaryGold = "#C9A45C";
const goldLight = "#D4B76A";
const textDark = "#2D1E08";
const textMedium = "#7A6838";
const textLight = "#9A8A58";
const cream = "#F0E2C0";
const offWhite = "#F8F0D8";
const charcoal = "#1E1808";
const borderLight = "#D4C8A0";
const bgWhite = "#FFFBF0";
const bgHero = "#0D0A04";

/* ======= PRELOADER ======= */
const Preloader = ({ onComplete }: { onComplete: () => void }) => {
  const [progress, setProgress] = useState(0);
  const ref = useRef<HTMLDivElement>(null);

  useEffect(() => {
    let p = 0;
    const interval = setInterval(() => {
      p += Math.random() * 15;
      if (p >= 100) {
        p = 100;
        clearInterval(interval);
        setTimeout(() => {
          gsap.to(ref.current, {
            opacity: 0,
            duration: 0.6,
            ease: "power2.inOut",
            onComplete,
          });
        }, 400);
      }
      setProgress(Math.min(p, 100));
    }, 80);
    return () => clearInterval(interval);
  }, [onComplete]);

  return (
    <div
      ref={ref}
      style={{
        position: "fixed",
        inset: 0,
        zIndex: 100,
        background: bgHero,
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "center",
        gap: 32,
      }}
    >
      <img src="/assets/logo-main.png" alt="SerHair Center" style={{ height: 140, objectFit: "contain" }} />
      <div
        style={{
          width: 200,
          height: 2,
          background: "rgba(201,164,92,0.2)",
          position: "relative",
          overflow: "hidden",
        }}
      >
        <div
          style={{
            position: "absolute",
            inset: 0,
            background: primaryGold,
            transform: `scaleX(${progress / 100})`,
            transformOrigin: "left",
            transition: "transform 0.1s ease-out",
          }}
        />
      </div>
      <span
        style={{
          fontFamily: "var(--font-body)",
          fontSize: "0.75rem",
          fontWeight: 500,
          letterSpacing: "0.12em",
          color: textLight,
          textTransform: "uppercase",
        }}
      >
        YÜKLENİYOR
      </span>
    </div>
  );
};

/* ======= NAVIGATION ======= */
const Navigation = () => {
  const [scrolled, setScrolled] = useState(false);
  const [mobileOpen, setMobileOpen] = useState(false);

  useEffect(() => {
    const onScroll = () => {
      setScrolled(window.scrollY > window.innerHeight - 100);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, []);

  const scrollTo = (id: string) => {
    setMobileOpen(false);
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: "smooth" });
  };

  const navLinks = [
    { label: "ANASAYFA", id: "hero" },
    { label: "HİZMETLERİMİZ", id: "services" },
    { label: "SIKÇA SORULANLAR", id: "faq" },
    { label: "İLETİŞİM", id: "contact" },
  ];

  return (
    <>
      <nav
        style={{
          position: "fixed",
          top: 0,
          left: 0,
          right: 0,
          zIndex: 10,
          height: 72,
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          padding: "0 48px",
          transition: "all 0.3s ease",
          background: scrolled ? "rgba(255,251,240,0.95)" : "transparent",
          backdropFilter: scrolled ? "blur(12px)" : "none",
          borderBottom: scrolled ? `1px solid ${borderLight}` : "1px solid transparent",
        }}
      >
        <button
          onClick={() => scrollTo("hero")}
          style={{
            fontFamily: "var(--font-display)",
            fontSize: "1.25rem",
            fontWeight: 500,
            letterSpacing: "0.1em",
            color: scrolled ? primaryGold : bgWhite,
            background: "none",
            border: "none",
            cursor: "pointer",
          }}
        >
          <img src="/assets/logo-main.png" alt="SerHair Center" style={{ height: 48, objectFit: "contain" }} />
        </button>

        <div className="hidden md:flex" style={{ gap: 36, alignItems: "center" }}>
          {navLinks.map((link) => (
            <button
              key={link.id}
              onClick={() => scrollTo(link.id)}
              style={{
                fontFamily: "var(--font-body)",
                fontSize: "0.75rem",
                fontWeight: 500,
                letterSpacing: "0.1em",
                color: scrolled ? textDark : bgWhite,
                background: "none",
                border: "none",
                cursor: "pointer",
                position: "relative",
              }}
              onMouseEnter={(e) => {
                const underline = e.currentTarget.querySelector(".nav-underline") as HTMLElement;
                if (underline) underline.style.width = "100%";
              }}
              onMouseLeave={(e) => {
                const underline = e.currentTarget.querySelector(".nav-underline") as HTMLElement;
                if (underline) underline.style.width = "0%";
              }}
            >
              {link.label}
              <span
                className="nav-underline"
                style={{
                  position: "absolute",
                  bottom: -4,
                  left: 0,
                  width: "0%",
                  height: 1,
                  background: scrolled ? primaryGold : bgWhite,
                  transition: "width 0.3s ease",
                }}
              />
            </button>
          ))}
        </div>

        <div className="hidden md:block">
          <button
            onClick={() => scrollTo("contact")}
            style={{
              fontFamily: "var(--font-body)",
              fontSize: "0.875rem",
              fontWeight: 500,
              letterSpacing: "0.1em",
              textTransform: "uppercase",
              color: textDark,
              background: primaryGold,
              border: "none",
              height: 44,
              padding: "0 24px",
              cursor: "pointer",
              transition: "all 0.3s ease",
            }}
            onMouseEnter={(e) => {
              e.currentTarget.style.background = goldLight;
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.background = primaryGold;
            }}
          >
            Randevu Al
          </button>
        </div>

        <button
          className="md:hidden"
          onClick={() => setMobileOpen(!mobileOpen)}
          style={{
            background: "none",
            border: "none",
            cursor: "pointer",
            display: "flex",
            flexDirection: "column",
            gap: 5,
          }}
        >
          <span style={{ width: 24, height: 2, background: scrolled ? textDark : bgWhite, transition: "all 0.3s", transform: mobileOpen ? "rotate(45deg) translateY(7px)" : "none" }} />
          <span style={{ width: 24, height: 2, background: scrolled ? textDark : bgWhite, transition: "all 0.3s", opacity: mobileOpen ? 0 : 1 }} />
          <span style={{ width: 24, height: 2, background: scrolled ? textDark : bgWhite, transition: "all 0.3s", transform: mobileOpen ? "rotate(-45deg) translateY(-7px)" : "none" }} />
        </button>
      </nav>

      {mobileOpen && (
        <div
          style={{
            position: "fixed",
            inset: 0,
            zIndex: 9,
            background: primaryGold,
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            justifyContent: "center",
            gap: 32,
          }}
        >
          {navLinks.map((link) => (
            <button
              key={link.id}
              onClick={() => scrollTo(link.id)}
              style={{
                fontFamily: "var(--font-display)",
                fontSize: "2rem",
                color: textDark,
                background: "none",
                border: "none",
                cursor: "pointer",
              }}
            >
              {link.label}
            </button>
          ))}
          <button
            onClick={() => scrollTo("contact")}
            style={{
              fontFamily: "var(--font-body)",
              fontSize: "0.875rem",
              fontWeight: 500,
              letterSpacing: "0.1em",
              textTransform: "uppercase",
              color: primaryGold,
              background: textDark,
              border: "none",
              height: 48,
              padding: "0 32px",
              cursor: "pointer",
            }}
          >
            Randevu Al
          </button>
        </div>
      )}
    </>
  );
};

/* ======= SECTION HEADER ======= */
const SectionHeader = ({ label, title, light = false }: { label: string; title: string; light?: boolean }) => {
  const titleRef = useRef<HTMLHeadingElement>(null);

  useEffect(() => {
    if (!titleRef.current) return;
    const split = new SplitType(titleRef.current, { types: "chars" });
    if (split.chars) {
      gsap.from(split.chars, {
        yPercent: 105,
        opacity: 0,
        duration: 0.6,
        stagger: 0.02,
        ease: "power3.out",
        scrollTrigger: {
          trigger: titleRef.current,
          start: "top 85%",
        },
      });
    }
    return () => {
      split.revert();
    };
  }, []);

  return (
    <div style={{ textAlign: "center", marginBottom: 64 }}>
      <div
        style={{
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          gap: 16,
          marginBottom: 20,
        }}
      >
        <span style={{ width: 60, height: 1, background: borderLight }} />
        <span
          style={{
            fontFamily: "var(--font-body)",
            fontSize: "0.75rem",
            fontWeight: 500,
            letterSpacing: "0.12em",
            color: primaryGold,
            textTransform: "uppercase",
          }}
        >
          {label}
        </span>
        <span style={{ width: 60, height: 1, background: borderLight }} />
      </div>
      <h2
        ref={titleRef}
        style={{
          fontFamily: "var(--font-display)",
          fontSize: "clamp(2rem, 4vw, 3.5rem)",
          fontWeight: 400,
          lineHeight: 1.2,
          letterSpacing: "-0.02em",
          color: light ? bgWhite : textDark,
          overflow: "hidden",
        }}
      >
        {title}
      </h2>
    </div>
  );
};

/* ======= SERVICE CARD ======= */
const ServiceCard = ({ number, icon, title, description, features }: { number: string; icon: React.ReactNode; title: string; description: string; features: string[] }) => {
  const ref = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (!ref.current) return;
    gsap.from(ref.current, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
      scrollTrigger: { trigger: ref.current, start: "top 85%" },
    });
  }, []);

  return (
    <div
      ref={ref}
      style={{
        background: cream,
        padding: 36,
        cursor: "default",
        transition: "transform 0.3s ease, box-shadow 0.3s ease",
        display: "flex",
        flexDirection: "column",
        height: "100%",
      }}
      onMouseEnter={(e) => {
        e.currentTarget.style.transform = "translateY(-4px)";
        e.currentTarget.style.boxShadow = "0 8px 32px rgba(45,30,8,0.12)";
      }}
      onMouseLeave={(e) => {
        e.currentTarget.style.transform = "translateY(0)";
        e.currentTarget.style.boxShadow = "none";
      }}
    >
      <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: 20 }}>
        <div style={{ color: primaryGold, flexShrink: 0 }}>{icon}</div>
        <span style={{ fontFamily: "var(--font-display)", fontSize: "0.875rem", color: primaryGold, opacity: 0.5, letterSpacing: "0.1em" }}>
          {number}
        </span>
      </div>
      <h3 style={{ fontFamily: "var(--font-display)", fontSize: "1.5rem", fontWeight: 500, color: textDark, marginBottom: 14, lineHeight: 1.3 }}>
        {title}
      </h3>
      <p style={{ fontFamily: "var(--font-body)", fontSize: "0.9375rem", color: textMedium, lineHeight: 1.7, marginBottom: 20 }}>
        {description}
      </p>
      <ul style={{ listStyle: "none", padding: 0, margin: 0, marginBottom: 24, flex: 1 }}>
        {features.map((f, i) => (
          <li key={i} style={{ display: "flex", alignItems: "flex-start", gap: 10, marginBottom: 10, fontFamily: "var(--font-body)", fontSize: "0.875rem", color: textDark, lineHeight: 1.5 }}>
            <span style={{ color: primaryGold, fontSize: "1rem", lineHeight: 1, marginTop: 2, flexShrink: 0 }}>+</span>
            {f}
          </li>
        ))}
      </ul>
      <span style={{ fontFamily: "var(--font-body)", fontSize: "0.75rem", fontWeight: 500, letterSpacing: "0.12em", color: primaryGold, textTransform: "uppercase", cursor: "pointer", display: "inline-flex", alignItems: "center", gap: 6, marginTop: "auto" }}>
        DETAYLI BİLGİ
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke={primaryGold} strokeWidth="1.5"/></svg>
      </span>
    </div>
  );
};

