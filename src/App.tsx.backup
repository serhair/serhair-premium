/* ======= WHY CHOOSE SECTION ======= */
const WhyChooseSection = () => {
  const sectionRef = useRef<HTMLDivElement>(null);
  const imageRef = useRef<HTMLDivElement>(null);
  const [counts, setCounts] = useState({ yil: 0, hasta: 0, greft: 0 });
  const hasAnimated = useRef(false);

  useEffect(() => {
    if (!imageRef.current) return;
    gsap.from(imageRef.current, {
      clipPath: "inset(0 100% 0 0)",
      duration: 1.2,
      ease: "power4.inOut",
      scrollTrigger: { trigger: imageRef.current, start: "top 80%" },
    });
  }, []);

  useEffect(() => {
    if (!sectionRef.current) return;
    const trigger = ScrollTrigger.create({
      trigger: sectionRef.current,
      start: "top 75%",
      onEnter: () => {
        if (hasAnimated.current) return;
        hasAnimated.current = true;
        const obj = { yil: 0, hasta: 0, greft: 0 };
        gsap.to(obj, {
          yil: 15,
          hasta: 10000,
          greft: 50000,
          duration: 2,
          ease: "power2.out",
          onUpdate: () => {
            setCounts({ yil: Math.floor(obj.yil), hasta: Math.floor(obj.hasta), greft: Math.floor(obj.greft) });
          },
        });
      },
    });
    return () => trigger.kill();
  }, []);

  return (
    <section ref={sectionRef} style={{ background: offWhite, padding: "120px 24px" }}>
      <div style={{ maxWidth: 1280, margin: "0 auto", display: "grid", gridTemplateColumns: "1fr 1fr", gap: 64, alignItems: "center" }} className="why-grid">
        <div ref={imageRef} style={{ position: "relative" }}>
          <div style={{ position: "absolute", top: -16, left: -16, right: 16, bottom: 16, border: `2px solid ${primaryGold}`, zIndex: 0 }} />
          <img
            src="/assets/img-clinic.jpg"
            alt="Modern saç ekim kliniği"
            style={{ width: "100%", height: "auto", aspectRatio: "3/4", objectFit: "cover", position: "relative", zIndex: 1 }}
          />
        </div>
        <div>
